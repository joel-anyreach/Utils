# Apify — YouTube channel discovery + email enrichment (same token for both)
APIFY_API_TOKEN=your_apify_api_token_here
APIFY_ACTOR_ID=badruddeen/youtube-niche-channel-finder
APIFY_EMAIL_ACTOR_ID=endspec/youtube-instant-email-scraper
APIFY_MAX_RESULTS=200
YOUTUBE_API_KEY=your_youtube_data_api_v3_key_here

# Instantly — outreach campaign
INSTANTLY_API_KEY=your_instantly_api_key_here
INSTANTLY_CAMPAIGN_ID=your_campaign_uuid_here

# Reoon EmailVerifier — optional, required only when using --verify-emails / "Verify (Reoon)" toggle
# Get your API key at https://emailverifier.reoon.com
REOON_API_KEY=

# Google Sheets — leads database (OAuth as demo@anyreach.ai)
GOOGLE_SHEET_ID=your_google_sheet_id_here
GOOGLE_OAUTH_CREDENTIALS_FILE=oauth_credentials.json
GOOGLE_OAUTH_TOKEN_FILE=oauth_token.json
SHEET_TAB_NAME=Leads
