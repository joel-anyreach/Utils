# ── Streamlit Cloud Secrets Template ──────────────────────────────────────────
# Copy this file's contents into your app's Secrets panel on share.streamlit.io
# (App settings → Secrets). Do NOT commit the real secrets.toml to git.

# Apify
APIFY_API_TOKEN       = "your_apify_api_token_here"
APIFY_ACTOR_ID        = "badruddeen/youtube-niche-channel-finder"
APIFY_EMAIL_ACTOR_ID  = "endspec/youtube-instant-email-scraper"
APIFY_MAX_RESULTS     = "200"
YOUTUBE_API_KEY       = "your_youtube_data_api_v3_key_here"

# Instantly
INSTANTLY_API_KEY     = "your_instantly_api_key_here"
INSTANTLY_CAMPAIGN_ID = "your_campaign_uuid_here"

# Reoon (optional — only needed when Verify toggle is on)
REOON_API_KEY         = ""

# Google Sheets
GOOGLE_SHEET_ID       = "your_google_sheet_id_here"
SHEET_TAB_NAME        = "Leads"

# Google OAuth credentials — paste the full JSON file contents as a single-line string.
# To get these values, run:  python -c "import json,pathlib; print(json.dumps(json.loads(pathlib.Path('oauth_credentials.json').read_text())))"
GOOGLE_OAUTH_CREDENTIALS_JSON = '{"installed":{"client_id":"...","client_secret":"...","redirect_uris":["..."],...}}'

# To get this value, run:  python -c "import json,pathlib; print(json.dumps(json.loads(pathlib.Path('oauth_token.json').read_text())))"
GOOGLE_OAUTH_TOKEN_JSON = '{"token":"...","refresh_token":"...","token_uri":"...","client_id":"...","client_secret":"...",...}'
