# ──────────────────────────────────────────────────────────────────────────────
# Streamlit Cloud Secrets — EXAMPLE FILE
# ──────────────────────────────────────────────────────────────────────────────
# DO NOT commit the real secrets.toml to GitHub.
# In Streamlit Cloud: go to your app → Settings → Secrets → paste this content
# with your real API keys filled in.
#
# Each provider section uses:  "Key Label" = "actual-api-key"
# You can add multiple keys per provider (they'll appear as a dropdown).
# ──────────────────────────────────────────────────────────────────────────────

[Reoon]
"Production Key" = "your-reoon-api-key-here"
# "Backup Key"   = "another-reoon-key"

[ZeroBounce]
"Main" = "your-zerobounce-api-key-here"

[NeverBounce]
"Main" = "your-neverbounce-api-key-here"

[Hunter]
"Main" = "your-hunter-api-key-here"

[Gemini]
"Main" = "your-gemini-api-key-here"
# Get a free key at https://aistudio.google.com/apikey
# Free tier: ~1,500 requests/day | Paid tier: unlimited
