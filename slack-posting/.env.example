# ─── Instantly.ai ────────────────────────────────────────────────────────────
# Your API v2 key from: Instantly → Settings → API → Create API Key
INSTANTLY_API_KEY=

# ─── Slack ────────────────────────────────────────────────────────────────────
# Bot token from your Slack app (starts with xoxb-)
# Required OAuth scope: chat:write
SLACK_BOT_TOKEN=

# Channel ID (NOT the channel name — right-click channel → View details → copy the ID starting with C)
SLACK_CHANNEL_ID=

# ─── Schedule ─────────────────────────────────────────────────────────────────
# IANA timezone name. America/Los_Angeles covers both PST and PDT automatically.
CRON_TIMEZONE=America/Los_Angeles
